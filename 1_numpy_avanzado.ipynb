import random
def generar_matriz (N):
    matriz = []
    for i in range (N):
        fila = []
        for j in range (N): 
            fila.append (random.randint(1, 9))
    matriz.append(fila)
    return matriz
    N=5
    matriz_aleatoria = generar_matriz(N)
